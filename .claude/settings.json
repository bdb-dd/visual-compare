{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./docker-config/.env)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./deploy/scaleway/provision.env)",
      "Read(./deploy/scaleway/state.env)",
      "Bash(cat *.env*)",
      "Bash(type *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(Get-Content *.env*)"
    ]
  }
}
