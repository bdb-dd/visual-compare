# Copy to provision.env and fill in. provision.env is git-ignored.
#
# Scaleway account / auth — these match the env var names the `scw` CLI
# and official Scaleway SDKs read by default. Sourcing this file in your
# shell is enough to make `scw` authenticate; the provisioning script
# also reads them directly.
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
SCW_DEFAULT_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Zones for each VM. The API VM and GPU VM can live in different zones —
# Scaleway charges no inter-zone traffic within the same region, and L4
# capacity is only in fr-par-2 / ams-1 at the moment.
SCW_API_ZONE=fr-par-1
SCW_GPU_ZONE=fr-par-2

# Public domain. DNS A record must point to API_PUBLIC_IP after provisioning.
DOMAIN=visual-compare.example.com
ACME_EMAIL=ops@example.com

# Basic-auth credential for Caddy. Generate the hash with:
#   docker run --rm caddy:latest caddy hash-password --plaintext 'your-password'
# or, on the API VM after first deploy:
#   caddy hash-password --plaintext 'your-password'
BASIC_AUTH_USER=team
BASIC_AUTH_HASH='$2a$14$REPLACE_ME_WITH_BCRYPT_HASH'

# LM Studio model id — must match what `lms get` accepts.
LM_STUDIO_MODEL=google/gemma-3-4b-it
# Once the GPU instance has an IP (after the `gpu` step), set this to its
# private network IP and re-run the `api` step. The Scaleway private
# network avoids egress charges and keeps LM traffic off the public net.
LM_STUDIO_BASE_URL=http://10.0.0.2:1234/v1

# Instance types + images. Check `scw instance server-type list` for
# current SKUs in your zone.
#
#   API:  POP2-HC-8C-16G  (8 dedicated AMD EPYC vCPU / 16 GB)
#   GPU:  L40S-1-48G       (1× L40S / 48 GB VRAM / 96 GB RAM)
#
# Sizing notes: the API tier was bumped from POP2-HC-4C-8G after benching
# the IM comparison pipeline — IM saturates cores, so going from 4 to 8
# roughly doubles comparison throughput. Combined with `MAGICK_NICE=10`
# the API stays responsive even at saturation. The GPU type is picked to
# comfortably host vision LMs in the 20–30B Q4_K_M range (~16–20 GB on
# disk + VRAM) with headroom for context + KV cache. L4-1-24G works for
# ≤12B-class models; L40S is the next step up. H100-1-80G is overkill
# unless you anticipate 70B+ models.
API_INSTANCE_TYPE=POP2-HC-8C-16G
API_IMAGE=ubuntu_noble
GPU_INSTANCE_TYPE=L40S-1-48G
# Use the Scaleway GPU OS image with drivers + CUDA preinstalled.
GPU_IMAGE=ubuntu_jammy_gpu_os_12

# Root volume size for the GPU instance. The Scaleway GPU image defaults
# to ~18 GB which is too small once you account for a 15–20 GB GGUF
# model + OS + LM Studio install + scratch. 100 GB leaves room for
# multiple model variants without risking a mid-download disk-full.
GPU_ROOT_VOLUME_SIZE_GB=100

# Block storage volume on the API VM for /mnt/data (SQLite + images +
# lm-last-use). Independent from the GPU root volume above.
BLOCK_VOLUME_SIZE_GB=50

# SSH public key authorised to log in as `deploy@` on both VMs.
DEPLOY_SSH_KEY="ssh-ed25519 AAAA... your-key"

# Optional: pin the API VM's private IP into the GPU firewall ruleset.
# If unset the GPU listens on 0.0.0.0 (still gated by the Scaleway
# security group). Set after the API instance exists, then re-run the
# GPU cloud-init or apply nftables changes manually.
API_VM_PRIVATE_IP=
