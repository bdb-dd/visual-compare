# Copy this file to ./docker-config/.env (next to docker-compose.yml)
# and fill in your LM endpoint values. The entrypoint sources it before
# starting the API process.
#
# All variables here are read by readLmConfigFromEnv() in
# packages/api/src/services/lm.ts. See README.md "Running in Docker" for
# the full list of overrides.

# ---------------------------------------------------------------------------
# External LM endpoint (required if you want LM verdicts).
# Must be OpenAI-compatible (path ends in /v1).
# ---------------------------------------------------------------------------
LM_STUDIO_BASE_URL=https://your-llm-host.example/v1
LM_STUDIO_API_KEY=replace-me
LM_STUDIO_MODEL=your-vision-model-id

# Disable the local `lms` CLI lifecycle (no LM Studio inside the container).
# Set to `local` only if you bind-mount lms and want auto-start; `none` is
# the right setting for any external endpoint.
LM_BACKEND=none

# ---------------------------------------------------------------------------
# Optional tuning.
# ---------------------------------------------------------------------------
# LM_STUDIO_PROMPT_VERSION=v3
# LM_STUDIO_MAX_TOKENS=4096
# LM_STUDIO_TEMPERATURE=0.1
# LM_STUDIO_TIMEOUT_SECONDS=240
# LM_STUDIO_PARALLEL=2
# LM_STUDIO_INCLUDE_DIFF_IMAGE=false

# Rate-limit (per IP) on /api/*. Set REFILL_PER_SECOND=0 to disable.
# RATE_LIMIT_REFILL_PER_SECOND=5
# RATE_LIMIT_BURST=30
