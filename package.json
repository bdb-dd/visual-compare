{
  "name": "visual-compare",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "overrides": {
      "@types/express": "^5.0.0",
      "vite": "^7.3.3",
      "esbuild": "^0.27.7"
    }
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @visual-compare/api dev",
    "dev:web": "pnpm --filter @visual-compare/web dev",
    "start": "pnpm --filter @visual-compare/api start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "install:playwright": "pnpm --filter @visual-compare/api exec playwright install chromium",
    "share-images": "sh scripts/share-images-dir.sh",
    "import-capture-cache": "sh scripts/import-capture-cache.sh",
    "provision": "bash deploy/scaleway/scripts/provision.sh",
    "deploy": "bash deploy/scaleway/scripts/deploy.sh"
  }
}
